  "sql": "with totals as (\n  select\n    month,\n    sum(mrr) as total_mrr\n  from mrr_by_month\n  group by 1\n),\nchanges as (\n  select\n    month,\n    total_mrr,\n    total_mrr - lag(total_mrr) over (order by month) as mrr_change\n  from totals\n)\nselect *\nfrom changes\norder by month",
