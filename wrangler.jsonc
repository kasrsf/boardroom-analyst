{
  "name": "boardroom-analyst-demo",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-24",
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    {
      "pattern": "boardroom-analyst.kasrsf.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
